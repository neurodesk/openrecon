  "parameters": [
    {
      "id": "config",
      "label": { "en": "config" },
      "type": "choice",
      "values": [
        {
          "id": "openreconi2iexample",
          "name": { "en": "openreconi2iexample" }
        }
      ],
      "default": "openreconi2iexample",
      "information": { "en": "Define the config to be executed by MRD server" }
    },
    {
      "id": "sendoriginal",
      "label": { "en": "Send original images" },
      "type": "boolean",
      "information": { "en": "Pass the original 2D image stream back for scanner postprocessing" },
      "default": true
    },
    {
      "id": "invert",
      "label": { "en": "Invert" },
      "type": "boolean",
      "information": { "en": "Send inverted magnitude images" },
      "default": false
    },
    {
      "id": "upsampled",
      "label": { "en": "Upsampled" },
      "type": "boolean",
      "information": { "en": "Interpolate between slices and send one volume with twice as many slices" },
      "default": false
    },
    {
      "id": "segment",
      "label": { "en": "Segment" },
      "type": "boolean",
      "information": { "en": "Segment the brightest foreground object" },
      "default": true
    },
    {
      "id": "segmentgeometry",
      "label": { "en": "Segment geometry" },
      "type": "choice",
      "values": [
        {
          "id": "3d",
          "name": { "en": "3D volume" }
        },
        {
          "id": "2d",
          "name": { "en": "2D images" }
        }
      ],
      "default": "3d",
      "information": { "en": "Only affects Segment output. 3D packs one explicit MRD volume per source group with Keep_image_geometry=0. 2D sends one source-geometry mask image per source image with Keep_image_geometry=1." }
    },
    {
      "id": "detach3ddata",
      "label": { "en": "Detach 3D data" },
      "type": "boolean",
      "information": { "en": "Send explicit 3D outputs in separate MRD image messages and stamp Segment 3D output with Detached3DData=1. Does not change 2D segment geometry." },
      "default": false
    },
    {
      "id": "segmentsendorder",
      "label": { "en": "Segment send order" },
      "type": "choice",
      "values": [
        {
          "id": "after_originals",
          "name": { "en": "After originals" }
        },
        {
          "id": "before_originals",
          "name": { "en": "Before originals" }
        }
      ],
      "default": "after_originals",
      "information": { "en": "When Segment and Send original images are both enabled, choose whether segment outputs are sent before or after original outputs." }
    },
    {
      "id": "segmentpostprocessingstamp",
      "label": { "en": "Stamp segment for postprocessing" },
      "type": "boolean",
      "information": { "en": "Send Segment as source-geometry 2D masks with SegmentPostProcessing metadata. This disables Send original images, ignores Detach 3D data, and preserves the source image-type identity used by scanner compose filters." },
      "default": false
    },
    {
      "id": "segmentationcolormap",
      "label": { "en": "Segmentation colourmap" },
      "type": "boolean",
      "information": { "en": "Add MicroDeltaHotMetal.pal LUT metadata to segmentation outputs" },
      "default": false
    },
    {
      "id": "mip",
      "label": { "en": "MIP" },
      "type": "boolean",
      "information": { "en": "Compute and send one maximum intensity projection image" },
      "default": false
    },
    {
      "id": "sendmetrics",
      "label": { "en": "Send metrics" },
      "type": "boolean",
      "information": { "en": "Send region volume in image comments and as a DICOM metrics table image" },
      "default": false
    }
  ]
