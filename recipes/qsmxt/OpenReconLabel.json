  "parameters": [
    {
      "id": "config",
      "label": { "en": "config" },
      "type": "choice",
      "values": [
        {
          "id": "qsmxt",
          "name": { "en": "qsmxt" }
        }
      ],
      "default": "qsmxt",
      "information": { "en": "Define the config to be executed by the MRD server." }
    },
    {
      "id": "sendoutputs",
      "label": { "en": "Output maps" },
      "type": "choice",
      "values": [
        { "id": "qsm", "name": { "en": "QSM only" } },
        { "id": "all", "name": { "en": "All available" } },
        { "id": "magnitude", "name": { "en": "Magnitude" } },
        { "id": "mask", "name": { "en": "Mask" } },
        { "id": "swi", "name": { "en": "SWI" } },
        { "id": "minip", "name": { "en": "SWI minIP" } },
        { "id": "t2star", "name": { "en": "T2 star" } },
        { "id": "r2star", "name": { "en": "R2 star" } }
      ],
      "default": "qsm",
      "information": { "en": "Select which QSMxT derivatives to send back to OpenRecon." }
    },
    {
      "id": "sendoriginal",
      "label": { "en": "Send original" },
      "type": "boolean",
      "information": { "en": "Send original magnitude and phase image series before derived QSMxT output." },
      "default": false
    },
    {
      "id": "maxechoes",
      "label": { "en": "Max echoes" },
      "type": "int",
      "minimum": 0,
      "maximum": 128,
      "default": 0,
      "information": { "en": "Maximum magnitude/phase echo pairs to write. Use 0 for all pairs." }
    },
    {
      "id": "echotimesms",
      "label": { "en": "Echo times" },
      "type": "string",
      "default": "",
      "information": { "en": "Optional comma-separated echo times in ms. Used when MRD metadata does not carry TE." }
    },
    {
      "id": "echotimems",
      "label": { "en": "First echo" },
      "type": "double",
      "minimum": 0.1,
      "maximum": 1000.0,
      "default": 20.0,
      "unit": { "en": "ms" },
      "information": { "en": "Fallback first echo time in ms when echo times are not supplied." }
    },
    {
      "id": "echospacingms",
      "label": { "en": "Echo spacing" },
      "type": "double",
      "minimum": 0.0,
      "maximum": 1000.0,
      "default": 5.0,
      "unit": { "en": "ms" },
      "information": { "en": "Fallback spacing in ms used to extend missing echo times." }
    },
    {
      "id": "fieldstrength",
      "label": { "en": "Field strength" },
      "type": "double",
      "minimum": 0.1,
      "maximum": 20.0,
      "default": 3.0,
      "unit": { "en": "T" },
      "information": { "en": "Magnetic field strength written to QSMxT BIDS sidecars when not available in MRD metadata." }
    },
    {
      "id": "b0dir",
      "label": { "en": "B0 direction" },
      "type": "string",
      "default": "0,0,1",
      "information": { "en": "B0 direction vector written to QSMxT sidecars." }
    },
    {
