      "default": "default",
      "information": { "en": "Optional QSMxT phase unwrapping algorithm override." }
    },
    {
      "id": "bfalgorithm",
      "label": { "en": "Background" },
      "type": "choice",
      "values": [
        { "id": "default", "name": { "en": "Default" } },
        { "id": "vsharp", "name": { "en": "VSHARP" } },
        { "id": "pdf", "name": { "en": "PDF" } },
        { "id": "lbv", "name": { "en": "LBV" } },
        { "id": "ismv", "name": { "en": "iSMV" } },
        { "id": "sharp", "name": { "en": "SHARP" } }
      ],
      "default": "default",
      "information": { "en": "Optional QSMxT background field removal algorithm override." }
    },
    {
      "id": "maskpreset",
      "label": { "en": "Mask preset" },
      "type": "choice",
      "values": [
        { "id": "default", "name": { "en": "Default" } },
        { "id": "robust-threshold", "name": { "en": "Robust threshold" } },
        { "id": "bet", "name": { "en": "BET" } }
      ],
      "default": "default",
      "information": { "en": "Optional QSMxT masking preset override." }
    }
  ]
